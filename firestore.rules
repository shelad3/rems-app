rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserRole() {
      let doc = getUserDoc();
      return doc.data != null ? doc.data.role : null;
    }

    function isRole(role) {
      return isAuthenticated() && getUserRole() == role;
    }

    function isOwnerOf(docData) {
      return isAuthenticated() && (
        docData.landlordId == request.auth.uid
      );
    }

    function isAssignedCaretaker(docData) {
      return isAuthenticated() && docData.caretakerId == request.auth.uid;
    }

    // ===== USERS =====
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == uid || isRole('landlord');
      allow delete: if isRole('landlord');
    }

    // ===== PROPERTIES =====
    match /properties/{id} {
      allow read: if isAuthenticated();
      allow create: if isRole('landlord') || isRole('caretaker');
      allow update: if isRole('landlord') || isRole('caretaker');
      allow delete: if isRole('landlord');
    }

    // ===== UNITS =====
    match /units/{id} {
      allow read: if isAuthenticated();
      allow create: if isRole('landlord') || isRole('caretaker');
      allow update: if isRole('landlord') || isRole('caretaker');
      allow delete: if isRole('landlord');
    }

    // ===== APPLICATIONS =====
    match /applications/{id} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.tenantId
          || request.auth.uid == resource.data.caretakerId
          || isRole('landlord'));
      allow create: if isRole('tenant')
        && request.resource.data.tenantId == request.auth.uid;
      allow update: if isRole('caretaker') || isRole('landlord');
      allow delete: if isRole('landlord');
    }

    // ===== MAINTENANCE =====
    match /maintenance/{id} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.tenantId
          || request.auth.uid == resource.data.caretakerId
          || isRole('landlord'));
      allow create: if request.auth.uid == request.resource.data.tenantId;
      allow update: if isRole('caretaker') || isRole('landlord');
      allow delete: if isRole('landlord');
    }

    // ===== LEASES =====
    match /leases/{id} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.tenantId
          || isRole('landlord')
          || isRole('caretaker'));
      allow create: if isRole('landlord') || isRole('caretaker');
      allow update: if isRole('landlord');
      allow delete: if isRole('landlord');
    }

    // ===== OWNERS =====
    match /owners/{id} {
      allow read: if isAuthenticated();
      allow write: if isRole('landlord');
    }

    // ===== TENANTS =====
    match /tenants/{id} {
      allow read: if isAuthenticated();
      allow write: if isRole('landlord');
    }

    // ===== PAYMENTS =====
    match /payments/{id} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.tenantId
          || isRole('landlord')
          || isRole('caretaker'));
      allow create: if isAuthenticated();
      allow update: if isRole('landlord');
      allow delete: if isRole('landlord');
    }

    // ===== CHATS =====
    match /chats/{chatId} {
      allow read, write: if isAuthenticated();

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.senderId == request.auth.uid;
        allow update: if request.auth.uid == resource.data.senderId;
        allow delete: if false;
      }
    }

    // ===== NOTIFICATIONS =====
    match /notifications/{id} {
      allow read: if isAuthenticated()
        && request.auth.uid == resource.data.userId;
      allow write: if isAuthenticated();
    }

    // ===== DEFAULT: DENY ALL =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
